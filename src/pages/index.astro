---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import Musica from "../components/Musica.astro";

const response = await fetch("https://api.institutoalfa.org/api/songs");
const { songs } = await response.json();
---

<Layout>
	<section>
		<div
			class="bg-[#f8f9fc] px-16 py-12 flex flex-col gap-6 font-sans text-zinc-900"
		>
			<div class="flex flex-col gap-1">
				<div class="text-3xl font-semibold tracking-tight">
					Buenas Noches
				</div>
				<p class="text-zinc-500 text-sm">
					Tómate un respiro y encuentra tu equilibrio.
				</p>
			</div>

			<div class="flex flex-row gap-6 mt-2">
				<div
					class="relative w-[450px] h-[260px] rounded-[32px] overflow-hidden shadow-2xl shadow-indigo-100"
				>
					<img
						src="/parte1.png"
						alt="Meditación"
						class="w-full h-full object-cover"
					/>

					<div
						class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent p-8 flex flex-col justify-end"
					>
						<div
							class="text-white/70 text-[10px] uppercase tracking-widest font-bold mb-1"
						>
							Escuchando Ahora
						</div>
						<div class="text-3xl font-bold text-white mb-1">
							Meditación de Medianoche
						</div>

						<div
							class="flex items-center gap-2 text-white/80 text-sm"
						>
							<div class="inline">Arlo Parks</div>
							<div class="opacity-40">•</div>
							<div class="inline">2:45</div>
						</div>
					</div>

					<div
						class="absolute bottom-8 right-8 bg-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg cursor-pointer"
					>
						<div class="flex gap-1">
							<div class="w-[3px] h-5 bg-indigo-900 rounded-full">
							</div>
							<div class="w-[3px] h-5 bg-indigo-900 rounded-full">
							</div>
						</div>
					</div>
				</div>

				<div class="flex flex-col gap-4 flex-1">
					<div
						class="bg-white/50 border border-white p-4 rounded-3xl flex flex-row items-center gap-4 hover:bg-white transition-colors cursor-pointer"
					>
						<img
							src="/parte1.1.png"
							alt="Solitude"
							class="w-14 h-14 rounded-2xl object-cover shadow-sm"
						/>
						<div class="flex-1">
							<div class="font-bold text-zinc-800">Soledad</div>
							<p class="text-zinc-400 text-xs">Ry X</p>
						</div>
						<div class="text-zinc-300 pr-2">⋮</div>
					</div>

					<div
						class="bg-white/50 border border-white p-4 rounded-3xl flex flex-row items-center gap-4 hover:bg-white transition-colors cursor-pointer"
					>
						<img
							src="/parte1.2.png"
							alt="After Dark"
							class="w-14 h-14 rounded-2xl object-cover shadow-sm"
						/>
						<div class="flex-1">
							<div class="font-bold text-zinc-800">
								Después del Anochecer
							</div>
							<p class="text-zinc-400 text-xs">The Weeknd</p>
						</div>
						<div class="text-zinc-300 pr-2">⋮</div>
					</div>
				</div>
			</div>
		</div>
	</section>
	<section>
		<div
			class="bg-[#fcfcfd] px-16 py-12 flex flex-col gap-12 font-sans text-zinc-900"
		>
			<div class="flex flex-col gap-6">
				<div class="flex justify-between items-end">
					<div class="text-2xl font-bold tracking-tight">
						Reproducido Recientemente
					</div>
					<div
						class="text-[10px] uppercase tracking-widest font-bold text-zinc-400 cursor-pointer hover:text-zinc-600"
					>
						Ver Todo
					</div>
				</div>

				<div class="flex flex-row justify-between gap-4">
					<div
						class="flex flex-col gap-3 w-[15%] group cursor-pointer"
					>
						<div
							class="aspect-square rounded-3xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
						>
							<img
								src="/parte2.png"
								alt="Pacific Breeze"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col items-center text-center">
							<div class="text-[13px] font-bold">
								Pacific Breeze
							</div>
							<p class="text-zinc-400 text-[11px]">
								Japanese City Pop
							</p>
						</div>
					</div>

					<div
						class="flex flex-col gap-3 w-[15%] group cursor-pointer"
					>
						<div
							class="aspect-square rounded-3xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
						>
							<img
								src="/parte2.1.png"
								alt="Golden Hour"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col items-center text-center">
							<div class="text-[13px] font-bold">Golden Hour</div>
							<p class="text-zinc-400 text-[11px]">
								Kacey Musgraves
							</p>
						</div>
					</div>

					<div
						class="flex flex-col gap-3 w-[15%] group cursor-pointer"
					>
						<div
							class="aspect-square rounded-3xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
						>
							<img
								src="/parte2.2.png"
								alt="Jazz Vibes"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col items-center text-center">
							<div class="text-[13px] font-bold">Jazz Vibes</div>
							<p class="text-zinc-400 text-[11px]">
								Blue Note Trio
							</p>
						</div>
					</div>

					<div
						class="flex flex-col gap-3 w-[15%] group cursor-pointer"
					>
						<div
							class="aspect-square rounded-3xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
						>
							<img
								src="/parte2.3.png"
								alt="Endless Sleep"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col items-center text-center">
							<div class="text-[13px] font-bold">
								Endless Sleep
							</div>
							<p class="text-zinc-400 text-[11px]">
								Ambient Focus
							</p>
						</div>
					</div>

					<div
						class="flex flex-col gap-3 w-[15%] group cursor-pointer"
					>
						<div
							class="aspect-square rounded-3xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
						>
							<img
								src="/parte2.4.png"
								alt="Coffee House"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col items-center text-center">
							<div class="text-[13px] font-bold">
								Coffee House
							</div>
							<p class="text-zinc-400 text-[11px]">Lo-fi Beats</p>
						</div>
					</div>

					<div
						class="flex flex-col gap-3 w-[15%] group cursor-pointer"
					>
						<div
							class="aspect-square rounded-3xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
						>
							<img
								src="/parte2.5.png"
								alt="Pulse"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col items-center text-center">
							<div class="text-[13px] font-bold">Pulse</div>
							<p class="text-zinc-400 text-[11px]">Bonobo</p>
						</div>
					</div>
				</div>
			</div>

			<div class="flex flex-col gap-6">
				<div class="flex justify-between items-end">
					<div class="text-2xl font-bold tracking-tight">
						Tus Playlists
					</div>
					<div
						class="text-[10px] uppercase tracking-widest font-bold text-zinc-400 cursor-pointer hover:text-zinc-600"
					>
						Descubrir Más
					</div>
				</div>

				<div class="flex flex-row gap-8">
					<div class="flex flex-col gap-4 w-1/4 cursor-pointer">
						<div
							class="aspect-square rounded-[32px] overflow-hidden grid grid-cols-2 grid-rows-2 gap-[2px] bg-white shadow-sm"
						>
							<img
								src="/parte3.1.png"
								class="w-full h-full object-cover"
							/>
							<img
								src="/parte3.1.png"
								class="w-full h-full object-cover"
							/>
							<img
								src="/parte3.1.png"
								class="w-full h-full object-cover"
							/>
							<img
								src="/parte3.1.png"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col gap-1">
							<div class="text-base font-bold">
								Morning Sanctuary
							</div>
							<p class="text-zinc-400 text-xs">
								42 Tracks • Creada para ti
							</p>
						</div>
					</div>

					<div class="flex flex-col gap-4 w-1/4 cursor-pointer">
						<div
							class="aspect-square rounded-[32px] overflow-hidden shadow-sm"
						>
							<img
								src="/parte3.png"
								alt="Deep Focus"
								class="w-full h-full object-cover"
							/>
						</div>
						<div class="flex flex-col gap-1">
							<div class="text-base font-bold">Deep Focus</div>
							<p class="text-zinc-400 text-xs">
								128 Tracks • Curada por Sanctuary
							</p>
						</div>
					</div>

					<div class="flex flex-col gap-4 w-1/4 cursor-pointer">
						<div
							class="aspect-square rounded-[32px] bg-indigo-50 flex items-center justify-center shadow-sm"
						>
							<div class="text-indigo-200 text-6xl">♥</div>
						</div>
						<div class="flex flex-col gap-1">
							<div class="text-base font-bold">
								Canciones que te gustan
							</div>
							<p class="text-zinc-400 text-xs">
								256 Tracks • Auto-actualizado
							</p>
						</div>
					</div>
				</div>
			</div>
			<div class="grid grid-cols-4 gap-4">
				{
					songs.map((song) => {
						return <Musica song={song} />;
					})
				}
			</div>
		</div>
	</section>
</Layout>
