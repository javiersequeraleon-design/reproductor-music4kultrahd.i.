---
import "../styles/global.css"
import { Icon } from 'astro-icon/components'
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header class="flex justify-between items-center p-6">
			<script>
				const button = document.querySelector("button");
				button.addEventListener("click", () => {
					document.documentElement.classList.toggle("dark");
				});
			</script>
			</script>
			<div>
			</div>
			<div>
			</div>
			
		</header>
		<div>
			<slot />
		</div>

		<div class="fixed bottom-0 left-0 w-full">
			<div
				class="bg-slate-900 px-4 py-3 flex items-center justify-between"
			>
				<div class="flex items-center gap-3">
					<div class="bg-black rounded p-2">
						<div id="album-art" class="bg-gray-700 w-8 h-8 rounded-sm"></div>
					</div>
					<div class="flex flex-col">
						<div id="title" class="text-white text-sm font-bold">
							Midnight Pulse
						</div>
						<div id="artist" class="text-gray-400 text-xs">Neon Archway</div>
					</div>
				</div>

				<div class="flex items-center gap-8">
					<div class="flex flex-col items-center gap-1">
						<div class="text-blue-400 text-xs">Now Playing</div>
					</div>
					<div class="flex flex-col items-center gap-1">
						<div class="text-gray-400 text-xs">Playback</div>
					</div>
					<div class="flex flex-col items-center gap-1">
						<div class="text-gray-400 text-xs">Queue</div>
					</div>
				</div>

				<div class="flex items-center gap-4">
					<div class="flex items-center gap-2">
						<div class="text-gray-400 text-sm">Vol</div>
						<div
							class="bg-gray-700 rounded-full h-1 w-24 flex items-center"
						>
							<div class="bg-gray-400 h-1 w-16 rounded-full">
							</div>
						</div>
					</div>
					<div class="bg-gray-800 rounded p-1">
						<div class="w-4 h-4 border border-gray-400 rounded-sm">
						</div>
					</div>
				</div>
			</div>
		</div>

	</body>
</html>



